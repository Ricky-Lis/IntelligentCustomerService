# Qdrant 向量库
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_customer_service
# 若使用 Qdrant Cloud，可设置：
# QDRANT_URL=https://xxx.qdrant.io
# QDRANT_API_KEY=your-api-key

# OpenAI 兼容接口（LLM + Embedding）
OPENAI_API_KEY=sk-your-key
# 若使用第三方兼容接口，例如：
# OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# RAG 行为（可选）
# RAG_TOP_K=5
# RAG_CHUNK_SIZE=512
# RAG_CHUNK_OVERLAP=64

# MySQL (or set DATABASE_URL to override)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=your-password
DATABASE_NAME=customer_service
# DATABASE_URL=mysql+aiomysql://user:password@host:3306/dbname?charset=utf8mb4
